# ----------------------------------------------------------------------------
# Delower Hossen Tuhin — Portfolio  (.env.example)
# Copy this file to `.env.local` and fill in your own values before running.
# ----------------------------------------------------------------------------

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database (MongoDB Atlas connection string) ──────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ── Admin seed credentials (used by `npm run seed:admin`) ───────────────────
ADMIN_EMAIL=tuhindelower@gmail.com
ADMIN_PASSWORD=change-me-immediately
ADMIN_NAME=Delower Hossen Tuhin

# ── Contact form email delivery ─────────────────────────────────────────────
# Option A — Resend (recommended for Vercel deploys)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=onboarding@resend.dev
CONTACT_TO_EMAIL=dellowerhossentuhin@gmail.com

# Option B — SMTP (Gmail / any provider). Leave blank if using Resend.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Spam protection (Cloudflare Turnstile — optional) ───────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
